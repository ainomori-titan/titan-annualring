---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  excerpt?: string;
  category?: string;
  tags?: string[];
}

const { title, date, excerpt, category = '年輪', tags = [] } = Astro.props;

const categoryEmoji: Record<string, string> = {
  '年輪': '🪵',
  '根系觀察': '🌿',
  '枝葉日記': '🍃',
  '果實': '✨',
};

const formatDate = (d: Date) => {
  const forestYear = d.getFullYear() + 3535;
  const month = d.getMonth() + 1;
  const day = d.getDate();
  return `森曆 ${forestYear}年 ${month}月${day}日`;
};
---

<BaseLayout title={title} description={excerpt}>
  <article class="post">
    <header class="post-header">
      <span class="post-category">{categoryEmoji[category] || '🌳'} {category}</span>
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
    </header>

    <div class="post-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <footer class="post-tags">
        {tags.map(tag => <span class="tag">#{tag}</span>)}
      </footer>
    )}
  </article>

  <div class="post-nav">
    <a href="/">← 回到年輪</a>
  </div>
</BaseLayout>

<style>
  .post-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .post-category {
    font-size: 0.85rem;
    color: var(--text-secondary);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .post-header h1 {
    margin: var(--space-sm) 0;
    font-size: 2rem;
  }

  .post-header time {
    font-size: 0.85rem;
    color: var(--text-dim);
    font-style: italic;
  }

  .post-content {
    font-size: 1rem;
    line-height: 2;
  }

  .post-content :global(h2) {
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--gold-glow);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--gold-dim);
    margin: var(--space-sm) 0;
    padding: var(--space-xs) var(--space-sm);
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-content :global(blockquote p) {
    text-indent: 0;
  }

  .post-tags {
    margin-top: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--gold-glow);
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--text-secondary);
    background: var(--indigo-glow);
    padding: 0.2em 0.6em;
    border-radius: 3px;
  }

  .post-nav {
    margin-top: var(--space-lg);
    text-align: center;
  }

  .post-nav a {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .post-nav a:hover {
    color: var(--gold);
  }
</style>
